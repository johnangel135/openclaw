# Core
PORT=3000
NODE_ENV=production

# Admin access gate for /api/usage/* and admin proxy endpoints
# (/console is session-authenticated via /auth/login)
CONSOLE_ADMIN_TOKEN=replace_with_long_random_token

# Persistence
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
USAGE_RETENTION_DAYS=90

# Provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional proxy tuning
PROXY_UPSTREAM_TIMEOUT_MS=30000
PROXY_RATE_LIMIT_MAX_REQUESTS=60
PROXY_RATE_LIMIT_WINDOW_MS=60000
USAGE_REQUESTS_MAX_LIMIT=200

# Optional Redis for distributed sessions + rate limiting
# If unset/unreachable, OpenClaw automatically falls back to in-memory state.
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_CONNECT_TIMEOUT_MS=3000
# REDIS_KEY_PREFIX=openclaw:

# Optional allowlists (comma-separated, lowercase recommended)
# ALLOWED_LLM_PROVIDERS=openai,anthropic,gemini
# ALLOWED_LLM_MODELS=gpt-4o-mini,claude-3-5-sonnet-latest

# Security controls
# SECURITY_HEADERS_ENABLED=true
# TRUST_PROXY=false
# CORS_ALLOWED_ORIGINS=https://console.example.com
# SESSION_COOKIE_NAME=openclaw_session
# SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_SECURE=auto
# SESSION_COOKIE_DOMAIN=

# Encrypt user-stored API keys at rest (32-byte key in hex or base64)
# USER_KEYS_ENCRYPTION_KEY=
# DATA_PLANE_SHARED_TOKEN=replace_with_long_random_shared_secret

# Payments (Stripe) readiness baseline
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_SCALE=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
# STRIPE_SUCCESS_URL=https://your-app.example.com/billing/success
# STRIPE_CANCEL_URL=https://your-app.example.com/billing/cancel
# STRIPE_BILLING_PORTAL_RETURN_URL=https://your-app.example.com/billing
# STRIPE_CHECKOUT_MODE=stub   # stub|live
# STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# PostgreSQL TLS hardening (default is strict verification)
# PG_SSL_INSECURE_ALLOW=false
# Provide CA/cert chain if your DB uses a private/self-signed CA:
# PG_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# PG_CA_CERT_BASE64=LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0t...
