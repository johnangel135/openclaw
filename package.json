    "lint": "eslint src/**/*.js services/**/*.js scripts/**/*.js",
    "test": "node --test"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "helmet": "^7.2.0",
    "pg": "^8.20.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "supertest": "^7.2.2"
  },
  "license": "MIT"
}
