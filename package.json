{
  "name": "openclaw",
  "version": "1.0.0",
  "description": "OpenClaw control/data plane with auth, usage analytics, and billing",
  "main": "src/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node src/index.js",
    "start:control-plane": "node src/index.js",
    "start:data-plane": "node services/data-plane/index.js",
