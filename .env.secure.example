# OpenClaw secure baseline (example)
PORT=3000
NODE_ENV=production

# Required
CONSOLE_ADMIN_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# Provider credentials (set only what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Security hardening
USER_KEYS_ENCRYPTION_KEY=53462bec9c27f2d8421882593cb24257ed5c09e1fd553009a4f5b88b2da52c2b
PG_SSL_INSECURE_ALLOW=false
SECURITY_HEADERS_ENABLED=true
TRUST_PROXY=false
CORS_ALLOWED_ORIGINS=
SESSION_COOKIE_NAME=openclaw_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_DOMAIN=
ALLOWED_LLM_PROVIDERS=openai,anthropic,gemini
# Keep tight in production: list only approved models
ALLOWED_LLM_MODELS=

# Payments (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Optional explicit URLs (fallback: origin + /billing/{success|cancel})
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_BILLING_PORTAL_RETURN_URL=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Runtime tuning
USAGE_RETENTION_DAYS=90
PROXY_UPSTREAM_TIMEOUT_MS=30000
PROXY_RATE_LIMIT_MAX_REQUESTS=60
PROXY_RATE_LIMIT_WINDOW_MS=60000
USAGE_REQUESTS_MAX_LIMIT=200
